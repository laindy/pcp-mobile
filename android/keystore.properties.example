# Copy to keystore.properties and fill in (file is gitignored).
# Generate keystore:
#   keytool -genkey -v -keystore pcpttherapy-release.keystore \
#     -alias pcpttherapy -keyalg RSA -keysize 2048 -validity 10000 \
#     -storepass YOUR_STORE_PASSWORD -keypass YOUR_KEY_PASSWORD \
#     -dname "CN=PCP Innov, OU=Mobile, O=PCP Innov, L=Paris, ST=IDF, C=FR"
storePassword=YOUR_STORE_PASSWORD
keyPassword=YOUR_KEY_PASSWORD
keyAlias=pcpttherapy
storeFile=pcpttherapy-release.keystore
