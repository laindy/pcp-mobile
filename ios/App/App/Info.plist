<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>en</string>
	<key>CFBundleDisplayName</key>
        <string>PCPTherapy</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>PCPTherapy</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>NSHealthShareUsageDescription</key>
	<string>PCPTherapy lit vos donnees HealthKit pour synchroniser votre suivi therapeutique avec votre equipe soignante.</string>
	<key>NSHealthUpdateUsageDescription</key>
	<string>PCPTherapy peut ecrire certaines donnees que vous enregistrez explicitement dans l'application.</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>PCPTherapy accède à vos photos pour votre photo de profil et vos documents.</string>
	<key>NSCameraUsageDescription</key>
	<string>PCPTherapy utilise l'appareil photo pour prendre une photo de profil ou un document.</string>
